# ═════════════════════════════════════════════════════════════════════════════
# Configuration Template for Deel Analytics Platform
# ═════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in real values for your environment.
#
# SECURITY WARNING:
# - .env file is git-ignored and contains secrets
# - Never commit .env to version control
# - Keep .env.example in sync with actual variables, but use placeholder values
#
# Usage:
#   cp .env.example .env
#   # Edit .env with real values
#   docker-compose up -d

# ═════════════════════════════════════════════════════════════════════════════
# DATABASE CONFIGURATION (PostgreSQL)
# ═════════════════════════════════════════════════════════════════════════════

# Database admin user (used by docker-compose to initialize PostgreSQL)
POSTGRES_USER=postgres

# Database admin password (change this!)
DB_PASSWORD=changeme

# Default database name (created by postgres service)
POSTGRES_DB=deel

# ═════════════════════════════════════════════════════════════════════════════
# SERVICE CONNECTION STRINGS
# ═════════════════════════════════════════════════════════════════════════════

# Source database (reads orders, items, products, customers for backfill)
# Format: postgresql://user:password@host:port/database
POSTGRES_SOURCE_URL=postgresql://postgres:changeme@postgres:5432/deel

# Analytics database (writes aggregated data; same instance, different schema)
POSTGRES_ANALYTICS_URL=postgresql://postgres:changeme@postgres:5432/deel

# ═════════════════════════════════════════════════════════════════════════════
# KAFKA CONFIGURATION
# ═════════════════════════════════════════════════════════════════════════════

# Kafka broker addresses (comma-separated for multiple brokers)
# Internal (docker network): kafka:29092
# External (host): localhost:9092
KAFKA_BROKERS=kafka:29092

# ═════════════════════════════════════════════════════════════════════════════
# PIPELINE CONFIGURATION
# ═════════════════════════════════════════════════════════════════════════════

# Pipeline execution mode
# - backfill-only: Run backfill job and exit
# - stream-only: Skip backfill, run consumer indefinitely
# - backfill-then-stream: Run backfill first, then consumer (default)
PIPELINE_MODE=backfill-then-stream

# Batch size for backfill (number of rows per INSERT)
BATCH_SIZE=1000

# Connection pool settings
DB_POOL_MIN_CONNECTIONS=1
DB_POOL_MAX_CONNECTIONS=5

# ═════════════════════════════════════════════════════════════════════════════
# LOGGING CONFIGURATION
# ═════════════════════════════════════════════════════════════════════════════

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ═════════════════════════════════════════════════════════════════════════════
# API CONFIGURATION
# ═════════════════════════════════════════════════════════════════════════════

# API server binding (0.0.0.0 = listen on all interfaces)
API_HOST=0.0.0.0

# API server port
API_PORT=8000
